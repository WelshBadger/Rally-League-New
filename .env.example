# Copy this file to .env and fill in your values
# Get these from https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Get this from https://dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# The price you charge organisers per event (in pence, so 5000 = £50)
VITE_EVENT_PRICE_PENCE=5000

# Your app's public URL (used for Stripe redirect after payment)
VITE_APP_URL=https://your-rally-league-url.vercel.app
